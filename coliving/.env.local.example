# ── Backend connection ──────────────────────────────────────────────
# Copy to .env.local and adjust.
#
# Leave USE_REAL_API unset (or "false") to run the standalone demo with the
# in-repo /api Route Handlers — no backend server needed. This is the
# presentation/offline path.
#
# Set USE_REAL_API=true to connect the UI to the NestJS API in
# nested-mono/apps/api (run it on :4000 first — see its README-api.md).

NEXT_PUBLIC_USE_REAL_API=false

# Base URL of the NestJS REST API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Socket.io origin for realtime chat. Defaults to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
