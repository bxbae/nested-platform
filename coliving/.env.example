# ── API connection ──────────────────────────────────────────────────
# Where the NestJS API lives. Must match the backend's PORT.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Socket.io endpoint (real-time chat). Usually the same host as the API.
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# ── The important one ───────────────────────────────────────────────
# false → the app runs entirely on in-repo demo data (src/lib/*.ts). No backend
#         needed. Useful for pure UI work.
# true  → every page talks to the real API above. Requires the backend running.
#
# Several pages still fall back to demo data even when this is true (see
# ONBOARDING.md → "What's real vs mocked"). If a page shows data that doesn't
# match the database, that's why.
NEXT_PUBLIC_USE_REAL_API="true"
