# ── Database ────────────────────────────────────────────────────────
# PostgreSQL — Prisma reads this at generate/migrate/runtime.
DATABASE_URL="postgresql://nested:nested@localhost:5432/nested?schema=public"

# Redis — cache, Socket.io pub/sub adapter, and BullMQ queue connection.
REDIS_URL="redis://localhost:6379"

# ── Auth ────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"

# ── Social OAuth ────────────────────────────────────────────────────
# Each *_CALLBACK_URL points at THIS API (port 4000), not the frontend,
# and must be registered verbatim in the provider's developer console.
# A single missing character ("...googleusercontent.co", "ttps://") is the
# most common cause of invalid_client / KOE006 / "client info invalid".

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# KAKAO_CLIENT_ID is the REST API key (not JavaScript/Admin).
# KAKAO_CLIENT_SECRET is required only when 카카오 로그인 → 보안 →
# 클라이언트 시크릿 is set to 사용함; leave blank otherwise.
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_CALLBACK_URL="http://localhost:4000/auth/kakao/callback"

NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_CALLBACK_URL="http://localhost:4000/auth/naver/callback"

APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_CALLBACK_URL="http://localhost:4000/auth/apple/callback"

# ── Payments (server-side verification) ─────────────────────────────
TOSS_SECRET_KEY=""
PORTONE_API_KEY=""
PORTONE_API_SECRET=""
STRIPE_SECRET_KEY=""

# ── Storage ─────────────────────────────────────────────────────────
# Cloudinary is the path actually in use: the API signs an upload, the browser
# POSTs the file straight to Cloudinary, and we store the returned secure_url.
# Free tier, no card required — https://cloudinary.com → Dashboard shows all
# three values. Leave blank and the file picker degrades to "paste an image
# URL" rather than breaking.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Storage: AWS S3 + CloudFront (alternative, not currently configured) ──
# The presign flow in storage.service.ts is intact but unused. Fill these in
# and point the frontend at /storage/presign to switch over.
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="nested-uploads"
# CloudFront distribution domain that fronts the bucket.
CLOUDFRONT_DOMAIN="d1234abcd.cloudfront.net"
# For signed CDN URLs (private content). Optional — public assets skip these.
CLOUDFRONT_KEY_PAIR_ID=""
CLOUDFRONT_PRIVATE_KEY=""

# ── App ─────────────────────────────────────────────────────────────
PORT=4000
# Where the SPA lives. After a social login the API redirects the browser to
# ${FRONTEND_URL}/auth/callback#accessToken=…&refreshToken=…, so this must be
# set or OAuth silently lands on localhost in production.
FRONTEND_URL="http://localhost:3000"
# Comma-separated list of allowed frontend origins for CORS.
# Leave empty in local dev to reflect the request origin.
CORS_ORIGINS="http://localhost:3000"

ODSAY_API_KEY=