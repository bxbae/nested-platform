// Prisma schema for the Nested co-living platform.
// Covers the core domain from ARCHITECTURE.md §6.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum RoomType {
  ONE_ROOM
  SHARE_ROOM
  WHOLE_HOUSE
  APARTMENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GenderPolicy {
  ANY
  MALE_ONLY
  FEMALE_ONLY
}

// 공동 예약 동반자의 응답 상태.
// 예약을 만든 쪽(대표자)이 매칭된 상대를 지정하면 PENDING 으로 시작하고,
// 상대가 수락해야 ACCEPTED 가 된다. 동의 없이 이름이 묶이지 않도록 하는 장치.
enum CompanionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  COMPLETED
  NO_SHOW
  EARLY_CHECKOUT_REQUESTED
  EARLY_CHECKOUT_APPROVED
  EXTENSION_REQUESTED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String? // null for OAuth-only accounts
  name              String // 공개용 닉네임
  nicknameCompleted Boolean   @default(false)
  role              Role      @default(GUEST)
  provider          String? // "google" | null
  providerId        String?
  avatarColor       String    @default("#FF5A5F")
  // Profile photo (S3 URL). null → fall back to the avatarColor circle.
  avatarUrl         String?
  bio               String? // self-introduction (스토리보드 1-1 자기소개)
  age               Int? // optional, shown as "25세" on the profile card
  job               String? // optional occupation label (e.g. "학생")
  suspended         Boolean   @default(false)
  // Timestamp of email ownership confirmation. null = unverified.
  // Login is blocked while null (when a mail provider is configured).
  emailVerified     DateTime?
  // Set by an admin once identity has been checked (신분증·연락처 확인).
  // Distinct from emailVerified, which only proves the address works.
  verifiedAt        DateTime?
  // Set when the user deletes their own account. Distinct from `suspended`,
  // which is an admin action. Non-null means the account is gone: login is
  // blocked and the personal fields above have been anonymised.
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  gender            Gender    @default(OTHER)

  listings              Room[]                   @relation("HostRooms")
  reservations          Reservation[]
  // 내가 동반자로 초대된 예약들
  companionReservations Reservation[]            @relation("ReservationCompanion")
  reviews               Review[]
  messages              Message[]
  sessions              RefreshToken[]
  resetTokens           PasswordResetToken[]
  verificationTokens    EmailVerificationToken[]
  hostProfile           HostProfile?
  properties            Property[]               @relation("HostProperties")
  notifications         Notification[]
  wishlists             Wishlist[]
  favorites             Favorite[]
  reportsMade           Report[]                 @relation("Reporter")
  chatRooms             ChatRoom[]               @relation("GuestChatRooms")
  hostChatRooms         ChatRoom[]               @relation("HostChatRooms")
  settlements           Settlement[]
  posts                 Post[]
  comments              Comment[]
  preference            RoommatePreference?
  tenantReviewsWritten  TenantReview[]           @relation("TenantReviewAuthor")
  tenantReviewsReceived TenantReview[]           @relation("TenantReviewTenant")

  friendshipsA         Friendship[]         @relation("FriendshipUserA")
  friendshipsB         Friendship[]         @relation("FriendshipUserB")
  directConversationsA DirectConversation[] @relation("DirectParticipantA")
  directConversationsB DirectConversation[] @relation("DirectParticipantB")
  directMessages       DirectMessage[]      @relation("DirectMessageSender")

  @@index([provider, providerId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// One-time password-reset tokens.
//
// Only the SHA-256 hash is stored: a leaked database must not hand an attacker
// working reset links. The raw token exists only in the email we send.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime? // set on use, so a link can't be replayed
  createdAt DateTime  @default(now())

  @@index([userId])
}

// One-time email-verification tokens. Same design as PasswordResetToken:
// only the SHA-256 hash is stored; the raw token lives only in the email.
// Confirming a token stamps User.emailVerified and burns the row.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime? // set on use, so a link can't be replayed
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Room {
  id             String          @id @default(cuid())
  hostId         String
  host           User            @relation("HostRooms", fields: [hostId], references: [id])
  propertyId     String?
  property       Property?       @relation(fields: [propertyId], references: [id])
  name           String
  region         String
  // Street address the host attests to. Kept private (never returned by the
  // public search) — only the approximate lat/lng is exposed to guests.
  address        String?
  lat            Float
  lng            Float
  // Host attested this is a real listing they're authorised to rent.
  verifiedByHost Boolean         @default(false)
  roomType       RoomType
  // 함께 지낼 수 있는 최대 인원. 독채(WHOLE_HOUSE)는 통째로 빌리므로 정원
  // 개념이 없어 null 로 둔다. 나머지 타입은 등록 시 필수.
  capacity       Int?
  // 침실 개수. capacity(함께 지낼 사람 수)와는 다르다 —
  // "방 2개, 최대 3명" 같은 조합이 가능하다. 선택 항목이라 nullable.
  bedrooms       Int?
  genderPolicy   GenderPolicy    @default(ANY)
  monthlyRent    Int
  deposit        Int
  cleaningFee    Int
  maintenanceFee Int
  minStayMonths  Int             @default(3)
  availableFrom  DateTime
  petsAllowed    Boolean         @default(false)
  smokingAllowed Boolean         @default(false)
  parking        Boolean         @default(false)
  published      Boolean         @default(false)
  images         Image[]
  reservations   Reservation[]
  reviews        Review[]
  amenities      RoomAmenity[]
  calendar       CalendarBlock[]
  chatRooms      ChatRoom[]
  favorites      Favorite[]
  posts          Post[]
  createdAt      DateTime        @default(now())

  @@index([region])
  @@index([hostId])
  @@index([propertyId])
}

// A building/address that contains one or more rentable Rooms.
model Property {
  id        String   @id @default(cuid())
  hostId    String
  host      User     @relation("HostProperties", fields: [hostId], references: [id])
  title     String
  address   String
  region    String
  city      String
  zipCode   String?
  lat       Float
  lng       Float
  builtYear Int?
  floors    Int?
  rooms     Room[]
  createdAt DateTime @default(now())

  @@index([hostId])
  @@index([region])
}

// Extended profile for users acting as hosts (superhost, payout info, etc.).
model HostProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  superhost     Boolean  @default(false)
  responseRate  Int      @default(100)
  payoutBank    String?
  payoutAccount String?
  createdAt     DateTime @default(now())
}

model Image {
  id     String @id @default(cuid())
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  url    String
  order  Int    @default(0)
}

model Reservation {
  id                   String            @id @default(cuid())
  roomId               String
  room                 Room              @relation(fields: [roomId], references: [id])
  guestId              String
  guest                User              @relation(fields: [guestId], references: [id])
  // ── 공동 예약 (룸메이트와 함께 방 예약) ──
  // guest 가 대표자이자 결제자다. companion 은 함께 살 상대이며, 비용은
  // 대표자가 전액 결제하고 둘 사이 정산은 서비스 밖에서 이뤄진다.
  companionId          String?
  companion            User?             @relation("ReservationCompanion", fields: [companionId], references: [id])
  companionStatus      CompanionStatus?
  companionRespondedAt DateTime?
  checkIn              DateTime
  checkOut             DateTime
  months               Int
  status               ReservationStatus @default(PENDING_PAYMENT)
  monthlyRent          Int
  deposit              Int
  cleaningFee          Int
  maintenanceFee       Int
  serviceFee           Int
  discount             Int               @default(0)
  totalDueNow          Int
  payment              Payment?
  settlement           Settlement?
  // 게스트가 요청한 연장 개월 수 (승인 대기 중에만 값이 있음)
  extensionMonths      Int?
  tenantReview         TenantReview?
  createdAt            DateTime          @default(now())

  // DB-level guard against double-booking is enforced with an exclusion
  // constraint on (roomId, tstzrange(checkIn, checkOut)) via a migration.
  @@index([roomId, checkIn, checkOut])
  @@index([guestId])
  @@index([companionId])
}

model Payment {
  id            String        @id @default(cuid())
  reservationId String        @unique
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  provider      String // TOSS | PORTONE | STRIPE
  providerTxnId String
  amount        Int
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
}

model Review {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  rating    Int
  body      String
  hostReply String?
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  body       String?
  imageUrl   String? // S3 key served via CloudFront
  readBy     String[] @default([])
  createdAt  DateTime @default(now())

  @@index([chatRoomId, createdAt])
}

// ── Friendships ───────────────────────────────────────────────────
// A friendship is stored once. userAId/userBId are sorted before creation.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ── Direct messages between users ────────────────────────────────
model DirectConversation {
  id             String          @id @default(cuid())
  participantAId String
  participantBId String
  participantA   User            @relation("DirectParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User            @relation("DirectParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       DirectMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([participantAId, participantBId])
  @@index([participantAId, updatedAt])
  @@index([participantBId, updatedAt])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String?
  imageUrl       String?
  readBy         String[]           @default([])
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String // FIXED | PERCENT
  value       Int
  maxDiscount Int?
  minSpend    Int      @default(0)
  validFrom   DateTime
  validTo     DateTime
  usageLimit  Int?
  usedCount   Int      @default(0)
}

// ── Notifications ──────────────────────────────────────────────────
enum NotificationType {
  COMMENT

  ROOM_APPROVED
  ROOM_REJECTED

  RESERVATION_REQUESTED
  RESERVATION_CONFIRMED
  RESERVATION_COMPLETED
  RESERVATION_CANCELLED

  EARLY_CHECKOUT_REQUESTED
  EARLY_CHECKOUT_APPROVED
  EARLY_CHECKOUT_REJECTED

  PAYMENT
  REVIEW
  SYSTEM

  // 기존 알림 데이터 호환용
  MESSAGE
  RESERVATION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  targetUrl String?

  @@index([userId, read])
}

// ── Wishlist (a named collection) + Favorite (a saved room in it) ───
model Wishlist {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String     @default("찜 목록")
  favorites Favorite[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model Favorite {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId     String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  wishlistId String?
  wishlist   Wishlist? @relation(fields: [wishlistId], references: [id])
  createdAt  DateTime  @default(now())

  @@unique([userId, roomId])
  @@index([roomId])
}

// ── Reports (moderation) ───────────────────────────────────────────
enum ReportTargetType {
  ROOM
  REVIEW
  USER
  MESSAGE
  COMMUNITY_POST
  COMMUNITY_COMMENT
}

enum ReportStatus {
  RECEIVED
  IN_REVIEW
  RESOLVED
}

model Report {
  id         String           @id @default(cuid())
  reporterId String
  reporter   User             @relation("Reporter", fields: [reporterId], references: [id])
  targetType ReportTargetType
  targetId   String
  reason     String
  status     ReportStatus     @default(RECEIVED)
  createdAt  DateTime         @default(now())

  @@index([status])
}

// ── Amenities (many-to-many with Room) ─────────────────────────────
model Amenity {
  id    String        @id @default(cuid())
  key   String        @unique // "wifi", "parking", "rooftop"
  label String
  icon  String?
  rooms RoomAmenity[]
}

model RoomAmenity {
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomId, amenityId])
}

// ── ChatRoom (a conversation between a guest and a host about a room) ─
model ChatRoom {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id])
  guestId   String
  guest     User      @relation("GuestChatRooms", fields: [guestId], references: [id])
  hostId    String
  host      User      @relation("HostChatRooms", fields: [hostId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([roomId, guestId])
  @@index([hostId])
}

// ── CalendarBlock (availability / blocked dates per room) ───────────
model CalendarBlock {
  id      String   @id @default(cuid())
  roomId  String
  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  date    DateTime
  blocked Boolean  @default(true)
  reason  String?

  @@unique([roomId, date])
  @@index([roomId])
}

// ── Settlement (monthly host payout for a confirmed reservation) ────
enum SettlementStatus {
  SCHEDULED
  PAID
  ON_HOLD
}

model Settlement {
  id            String           @id @default(cuid())
  reservationId String           @unique
  reservation   Reservation      @relation(fields: [reservationId], references: [id])
  hostId        String
  host          User             @relation(fields: [hostId], references: [id])
  grossAmount   Int
  commission    Int
  netAmount     Int
  status        SettlementStatus @default(SCHEDULED)
  scheduledFor  DateTime
  paidAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([hostId, status])
}

// ── Community board ──────────────────────────────────────────────────
// Posts live on a house's board (houseId → Room). Comments are the replies
// the UI shows as "💬 N replies".

enum PostCategory {
  NOTICE
  EVENT
  CHORE
  MARKET
  CHAT
  SEEKING
}

enum PostStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model Post {
  id                    String       @id @default(cuid())
  roomId                String
  room                  Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId              String
  author                User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category              PostCategory @default(CHAT)
  status                PostStatus   @default(OPEN)
  title                 String
  body                  String
  pinned                Boolean      @default(false)
  lifestyleSnapshot     Json?
  sharedLifestyleFields String[]     @default([])
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  comments              Comment[]

  @@index([roomId, createdAt])
  @@index([category, status])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
}

// ── Roommate preference survey (onboarding) ──────────────────────────
// A user's living-style answers, captured during onboarding and reused by
// the profile editor (스토리보드 08) and the /match algorithm (스토리보드 07).
// One row per user (1:1), mirroring the HostProfile relation pattern.
// `isCompleted` gates entry to /match; the survey is submitted as a whole,
// so the nine answers are required (non-null) on a completed row.

enum NoiseSensitivity {
  QUIET // 조용한 환경 선호
  MODERATE // 보통
  LIVELY // 활기찬 분위기도 괜찮음
}

enum CleanlinessLevel {
  VERY_TIDY // 매우 깔끔하게 유지
  MODERATE // 적당히
  RELAXED // 느슨한 편
}

enum SmokingPreference {
  NON_SMOKING_ONLY // 비흡연 환경만 가능
  OUTDOOR_OK // 실외 흡연은 괜찮음
  SMOKING_OK // 흡연 무관
}

enum PetPreference {
  NO_PETS // 반려동물 불가
  CONDITIONAL // 조건부 가능
  PETS_OK // 반려동물 환영
}

enum VisitorPolicy {
  PRIOR_AGREEMENT // 사전 협의 필요
  OCCASIONAL_OK // 가끔은 괜찮음
  FREQUENT_OK // 자유롭게 허용
}

enum SleepPattern {
  EARLY_BIRD // 아침형
  FLEXIBLE // 유동적
  NIGHT_OWL // 저녁형
}

enum Sociability {
  PRIVATE // 각자 생활 선호
  BALANCED // 적당히
  SOCIAL // 자주 어울림
}

enum SharedSpaceStyle {
  MINIMAL // 최소한만 사용
  MODERATE // 보통
  COMMUNAL // 함께 자주 사용
}

enum DrinkingHabit {
  NON_DRINKER // 거의 안 함
  SOCIAL_DRINKER // 가끔
  FREQUENT // 자주
}

model RoommatePreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  noise       NoiseSensitivity
  cleanliness CleanlinessLevel
  smoking     SmokingPreference
  pets        PetPreference
  visitors    VisitorPolicy
  sleep       SleepPattern
  sociability Sociability
  sharedSpace SharedSpaceStyle
  drinking    DrinkingHabit

  // Free-text answer from the subjective step (스토리보드 1-3), optional.
  intro    String?
  // Keywords extracted from `intro` by a rule-based dictionary (no API cost
  // in the MVP; swappable for an LLM later without changing this shape).
  keywords String[] @default([])

  // True once the survey is submitted. /match entry checks this flag.
  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Notices & banners (관리자 콘텐츠) ─────────────────────────────────
// Platform-wide content managed by admins. No user relation: these belong to
// the service, not to any account. Notices show on a notices page; banners
// render on the home screen (스토리보드 02) filtered by `active`.

model Notice {
  id        String   @id @default(cuid())
  title     String
  body      String
  pinned    Boolean  @default(false) // 상단 고정
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned, createdAt])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  color     String // 배경색 (hex, e.g. "#FF5A5F")
  position  String // 노출 위치 (예: "메인 상단")
  linkUrl   String? // 클릭 시 이동 (선택)
  active    Boolean  @default(true) // 노출 여부 (홈 공개 조회가 이 값으로 필터)
  order     Int      @default(0) // 정렬 순서 (낮을수록 먼저)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

// ── 입주자 평가 (호스트 → 입주자) ──────────────────────────────────
// Review 는 "게스트가 숙소를 평가"하는 반대 방향이다. 여기서는 호스트가
// 계약이 끝난 입주자를 평가한다. 예약 1건당 1개.
model TenantReview {
  id            String      @id @default(cuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation("TenantReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        User        @relation("TenantReviewTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  rating        Int
  body          String
  createdAt     DateTime    @default(now())

  @@index([tenantId])
  @@index([authorId])
}
