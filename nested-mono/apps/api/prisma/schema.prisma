// Prisma schema for the Nested co-living platform.
// Covers the core domain from ARCHITECTURE.md §6.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum RoomType {
  ONE_ROOM
  SHARE_ROOM
  WHOLE_HOUSE
  APARTMENT
}

enum GenderPolicy {
  ANY
  MALE_ONLY
  FEMALE_ONLY
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  COMPLETED
  NO_SHOW
  EARLY_CHECKOUT_REQUESTED
  EARLY_CHECKOUT_APPROVED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?       // null for OAuth-only accounts
  name         String
  role         Role          @default(GUEST)
  provider     String?       // "google" | null
  providerId   String?
  avatarColor  String        @default("#FF5A5F")
  // Profile photo (S3 URL). null → fall back to the avatarColor circle.
  avatarUrl    String?
  bio          String?       // self-introduction (스토리보드 1-1 자기소개)
  age          Int?          // optional, shown as "25세" on the profile card
  job          String?       // optional occupation label (e.g. "학생")
  suspended    Boolean       @default(false)
  // Set when the user deletes their own account. Distinct from `suspended`,
  // which is an admin action. Non-null means the account is gone: login is
  // blocked and the personal fields above have been anonymised.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())

  listings     Room[]        @relation("HostRooms")
  reservations Reservation[]
  reviews      Review[]
  messages     Message[]
  sessions     RefreshToken[]
  resetTokens  PasswordResetToken[]
  hostProfile  HostProfile?
  properties   Property[]     @relation("HostProperties")
  notifications Notification[]
  wishlists    Wishlist[]
  favorites    Favorite[]
  reportsMade  Report[]       @relation("Reporter")
  chatRooms    ChatRoom[]     @relation("GuestChatRooms")
  settlements  Settlement[]
  posts        Post[]
  comments     Comment[]
  preference   RoommatePreference?

  @@index([provider, providerId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// One-time password-reset tokens.
//
// Only the SHA-256 hash is stored: a leaked database must not hand an attacker
// working reset links. The raw token exists only in the email we send.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime? // set on use, so a link can't be replayed
  createdAt DateTime @default(now())

  @@index([userId])
}

model Room {
  id             String       @id @default(cuid())
  hostId         String
  host           User         @relation("HostRooms", fields: [hostId], references: [id])
  propertyId     String?
  property       Property?    @relation(fields: [propertyId], references: [id])
  name           String
  region         String
  // Street address the host attests to. Kept private (never returned by the
  // public search) — only the approximate lat/lng is exposed to guests.
  address        String?
  lat            Float
  lng            Float
  // Host attested this is a real listing they're authorised to rent.
  verifiedByHost Boolean      @default(false)
  roomType       RoomType
  genderPolicy   GenderPolicy @default(ANY)
  monthlyRent    Int
  deposit        Int
  cleaningFee    Int
  maintenanceFee Int
  minStayMonths  Int          @default(3)
  availableFrom  DateTime
  petsAllowed    Boolean      @default(false)
  smokingAllowed Boolean      @default(false)
  parking        Boolean      @default(false)
  published      Boolean      @default(false)
  images         Image[]
  reservations   Reservation[]
  reviews        Review[]
  amenities      RoomAmenity[]
  calendar       CalendarBlock[]
  chatRooms      ChatRoom[]
  favorites      Favorite[]
  posts          Post[]
  createdAt      DateTime     @default(now())

  @@index([region])
  @@index([hostId])
  @@index([propertyId])
}

// A building/address that contains one or more rentable Rooms.
model Property {
  id        String   @id @default(cuid())
  hostId    String
  host      User     @relation("HostProperties", fields: [hostId], references: [id])
  title     String
  address   String
  region    String
  city      String
  zipCode   String?
  lat       Float
  lng       Float
  builtYear Int?
  floors    Int?
  rooms     Room[]
  createdAt DateTime @default(now())

  @@index([hostId])
  @@index([region])
}

// Extended profile for users acting as hosts (superhost, payout info, etc.).
model HostProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  superhost     Boolean  @default(false)
  responseRate  Int      @default(100)
  payoutBank    String?
  payoutAccount String?
  createdAt     DateTime @default(now())
}

model Image {
  id     String @id @default(cuid())
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  url    String
  order  Int    @default(0)
}

model Reservation {
  id             String            @id @default(cuid())
  roomId         String
  room           Room              @relation(fields: [roomId], references: [id])
  guestId        String
  guest          User              @relation(fields: [guestId], references: [id])
  checkIn        DateTime
  checkOut       DateTime
  months         Int
  status         ReservationStatus @default(PENDING_PAYMENT)
  monthlyRent    Int
  deposit        Int
  cleaningFee    Int
  maintenanceFee Int
  serviceFee     Int
  discount       Int               @default(0)
  totalDueNow    Int
  payment        Payment?
  settlement     Settlement?
  createdAt      DateTime          @default(now())

  // DB-level guard against double-booking is enforced with an exclusion
  // constraint on (roomId, tstzrange(checkIn, checkOut)) via a migration.
  @@index([roomId, checkIn, checkOut])
  @@index([guestId])
}

model Payment {
  id            String        @id @default(cuid())
  reservationId String        @unique
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  provider      String        // TOSS | PORTONE | STRIPE
  providerTxnId String
  amount        Int
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
}

model Review {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  rating    Int
  body      String
  hostReply String?
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  body       String?
  imageUrl   String?  // S3 key served via CloudFront
  readBy     String[] @default([])
  createdAt  DateTime @default(now())

  @@index([chatRoomId, createdAt])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   // FIXED | PERCENT
  value       Int
  maxDiscount Int?
  minSpend    Int      @default(0)
  validFrom   DateTime
  validTo     DateTime
  usageLimit  Int?
  usedCount   Int      @default(0)
}

// ── Notifications ──────────────────────────────────────────────────
enum NotificationType {
  RESERVATION
  PAYMENT
  MESSAGE
  REVIEW
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

// ── Wishlist (a named collection) + Favorite (a saved room in it) ───
model Wishlist {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String     @default("찜 목록")
  favorites Favorite[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model Favorite {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId     String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  wishlistId String?
  wishlist   Wishlist? @relation(fields: [wishlistId], references: [id])
  createdAt  DateTime  @default(now())

  @@unique([userId, roomId])
  @@index([roomId])
}

// ── Reports (moderation) ───────────────────────────────────────────
enum ReportTargetType {
  ROOM
  REVIEW
  USER
  MESSAGE
}

enum ReportStatus {
  RECEIVED
  IN_REVIEW
  RESOLVED
}

model Report {
  id         String           @id @default(cuid())
  reporterId String
  reporter   User             @relation("Reporter", fields: [reporterId], references: [id])
  targetType ReportTargetType
  targetId   String
  reason     String
  status     ReportStatus     @default(RECEIVED)
  createdAt  DateTime         @default(now())

  @@index([status])
}

// ── Amenities (many-to-many with Room) ─────────────────────────────
model Amenity {
  id    String        @id @default(cuid())
  key   String        @unique // "wifi", "parking", "rooftop"
  label String
  icon  String?
  rooms RoomAmenity[]
}

model RoomAmenity {
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomId, amenityId])
}

// ── ChatRoom (a conversation between a guest and a host about a room) ─
model ChatRoom {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id])
  guestId   String
  guest     User      @relation("GuestChatRooms", fields: [guestId], references: [id])
  hostId    String
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([roomId, guestId])
  @@index([hostId])
}

// ── CalendarBlock (availability / blocked dates per room) ───────────
model CalendarBlock {
  id      String   @id @default(cuid())
  roomId  String
  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  date    DateTime
  blocked Boolean  @default(true)
  reason  String?

  @@unique([roomId, date])
  @@index([roomId])
}

// ── Settlement (monthly host payout for a confirmed reservation) ────
enum SettlementStatus {
  SCHEDULED
  PAID
  ON_HOLD
}

model Settlement {
  id            String           @id @default(cuid())
  reservationId String           @unique
  reservation   Reservation      @relation(fields: [reservationId], references: [id])
  hostId        String
  host          User             @relation(fields: [hostId], references: [id])
  grossAmount   Int
  commission    Int
  netAmount     Int
  status        SettlementStatus @default(SCHEDULED)
  scheduledFor  DateTime
  paidAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([hostId, status])
}

// ── Community board ──────────────────────────────────────────────────
// Posts live on a house's board (houseId → Room). Comments are the replies
// the UI shows as "💬 N replies".

enum PostCategory {
  NOTICE
  EVENT
  CHORE
  MARKET
  CHAT
  SEEKING
}

model Post {
  id        String       @id @default(cuid())
  roomId    String
  room      Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  PostCategory @default(CHAT)
  title     String
  body      String
  pinned    Boolean      @default(false)
  createdAt DateTime     @default(now())
  comments  Comment[]

  @@index([roomId, createdAt])
  @@index([category])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

// ── Roommate preference survey (onboarding) ──────────────────────────
// A user's living-style answers, captured during onboarding and reused by
// the profile editor (스토리보드 08) and the /match algorithm (스토리보드 07).
// One row per user (1:1), mirroring the HostProfile relation pattern.
// `isCompleted` gates entry to /match; the survey is submitted as a whole,
// so the nine answers are required (non-null) on a completed row.

enum NoiseSensitivity {
  QUIET      // 조용한 환경 선호
  MODERATE   // 보통
  LIVELY     // 활기찬 분위기도 괜찮음
}

enum CleanlinessLevel {
  VERY_TIDY  // 매우 깔끔하게 유지
  MODERATE   // 적당히
  RELAXED    // 느슨한 편
}

enum SmokingPreference {
  NON_SMOKING_ONLY // 비흡연 환경만 가능
  OUTDOOR_OK       // 실외 흡연은 괜찮음
  SMOKING_OK       // 흡연 무관
}

enum PetPreference {
  NO_PETS      // 반려동물 불가
  CONDITIONAL  // 조건부 가능
  PETS_OK      // 반려동물 환영
}

enum VisitorPolicy {
  PRIOR_AGREEMENT // 사전 협의 필요
  OCCASIONAL_OK   // 가끔은 괜찮음
  FREQUENT_OK     // 자유롭게 허용
}

enum SleepPattern {
  EARLY_BIRD // 아침형
  FLEXIBLE   // 유동적
  NIGHT_OWL  // 저녁형
}

enum Sociability {
  PRIVATE   // 각자 생활 선호
  BALANCED  // 적당히
  SOCIAL    // 자주 어울림
}

enum SharedSpaceStyle {
  MINIMAL  // 최소한만 사용
  MODERATE // 보통
  COMMUNAL // 함께 자주 사용
}

enum DrinkingHabit {
  NON_DRINKER    // 거의 안 함
  SOCIAL_DRINKER // 가끔
  FREQUENT       // 자주
}

model RoommatePreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  noise       NoiseSensitivity
  cleanliness CleanlinessLevel
  smoking     SmokingPreference
  pets        PetPreference
  visitors    VisitorPolicy
  sleep       SleepPattern
  sociability Sociability
  sharedSpace SharedSpaceStyle
  drinking    DrinkingHabit

  // Free-text answer from the subjective step (스토리보드 1-3), optional.
  intro       String?
  // Keywords extracted from `intro` by a rule-based dictionary (no API cost
  // in the MVP; swappable for an LLM later without changing this shape).
  keywords    String[] @default([])

  // True once the survey is submitted. /match entry checks this flag.
  isCompleted Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
